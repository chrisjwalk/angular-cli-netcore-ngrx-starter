    "dotnet:coverage": "dotnet tool install --global dotnet-coverage",
    "dotnet:outdated": "dotnet tool install --global dotnet-outdated-tool",
    "dotnet:clean": "dotnet clean apps/api",
    "dotnet:build": "dotnet build apps/api",
    "dotnet:update": "dotnet outdated -u apps/api",
    "preinstall": "pnpm dotnet:restore",
    "postinstall": "pnpm build:dotnet-builder",
    "prepare": "husky",
    "update-packages": "bun run ./tools/update-packages/src/main.tsx",
    "build:all": "nx run-many --target=build --projects=web-app,api --parallel"
